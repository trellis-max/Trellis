# =============================================================================
# Trellis — Environment Variables
# =============================================================================
# Copy to .env.local for local development. All secrets go in Vercel/Supabase
# runtime env — NEVER commit actual values.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Magic-Link Auth ---
MAGIC_LINK_SECRET=generate-128-bit-min-secret-here

# --- Anthropic (AI Engine) ---
# Scoped key with Console spend cap configured
ANTHROPIC_API_KEY=sk-ant-placeholder

# --- Deepgram (Speech-to-Text) ---
DEEPGRAM_API_KEY=placeholder

# --- Resend (Email) ---
RESEND_API_KEY=placeholder
RESEND_FROM_DOMAIN=placeholder.com

# --- Twilio (SMS — A2P gated) ---
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_MESSAGING_SERVICE_SID=placeholder

# --- QuickBooks Online (OAuth) ---
QB_CLIENT_ID=placeholder
QB_CLIENT_SECRET=placeholder
QB_REDIRECT_URI=placeholder
QB_REALM_ID=placeholder

# --- Square (OAuth + Payments) ---
SQUARE_APPLICATION_ID=placeholder
SQUARE_ACCESS_TOKEN=placeholder
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=placeholder

# --- Receipt Inbox ---
RECEIPT_INBOX_ADDRESS=placeholder
RECEIPT_INBOX_WEBHOOK_SECRET=placeholder
